# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Auth: Magic-Link via Supabase email provider. No external OAuth credentials needed.
# (Optional: switch to Entra OAuth later by setting AUTH_PROVIDER=entra and configuring the
#  ENTRA_* variables. For single-user MVP, magic-link is the default.)

# External data sources
ALPHAVANTAGE_KEY=
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_BACKUP_ID=

# Cron auth
CRON_SECRET=

# SMTP (default sender; per-user creds may live in Supabase Vault)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Buy & Sell Tool
